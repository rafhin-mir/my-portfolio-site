<footer class="site-footer">
  <div class="footer-top">
    <div class="footer-left">
      <a href="/" class="footer-logo-text">
        <img src="{{ site.logo }}" alt="{{ site.name }}">
      </a>
      <div class="footer-socials">
        {% for item in social %}
        <a href="{{ item.href }}" class="social-btn" aria-label="{{ item.label }}" target="_blank" rel="noopener">
          {% if item.icon == 'instagram' %}{% include "icons/instagram.njk" %}
          {% elif item.icon == 'tiktok' %}{% include "icons/tiktok.njk" %}
          {% elif item.icon == 'youtube' %}{% include "icons/youtube.njk" %}
          {% endif %}
        </a>
        {% endfor %}
      </div>
      <p class="footer-tagline">Built with intent. Made to last.</p>
    </div>
    <nav class="footer-nav-right">
      {% for item in nav %}
      <a href="{{ item.href }}" {% if pageKey == item.key %}class="footer-active"{% endif %}>{{ item.label }}</a>
      {% endfor %}
    </nav>
  </div>
  <div class="footer-bottom">
    <p class="footer-copy">© 2026 {{ site.name }}. All Rights Reserved.</p>
  </div>
</footer>
