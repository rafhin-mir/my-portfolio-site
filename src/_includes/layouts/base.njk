<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="index, follow">

  {# ── Primary meta ── #}
  <title>{{ title if title else site.name + " — " + site.tagline }}</title>
  <meta name="description" content="{{ description if description else site.description }}">
  <meta name="author" content="{{ site.name }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  {# ── Open Graph ── #}
  <meta property="og:type"        content="website">
  <meta property="og:site_name"   content="{{ site.name }}">
  <meta property="og:url"         content="{{ site.url }}{{ page.url }}">
  <meta property="og:title"       content="{{ title if title else site.name + ' — ' + site.tagline }}">
  <meta property="og:description" content="{{ description if description else site.description }}">
  <meta property="og:image"       content="{{ site.url }}{{ ogImage if ogImage else site.ogImage }}">

  {# ── Twitter Card ── #}
  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:site"        content="{{ site.twitterHandle }}">
  <meta name="twitter:title"       content="{{ title if title else site.name + ' — ' + site.tagline }}">
  <meta name="twitter:description" content="{{ description if description else site.description }}">
  <meta name="twitter:image"       content="{{ site.url }}{{ ogImage if ogImage else site.ogImage }}">

  {# ── Structured data ── #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "{{ site.name }}",
    "description": "{{ site.description }}",
    "url": "{{ site.url }}",
    "logo": "{{ site.url }}{{ site.logo }}",
    "email": "{{ site.email }}",
    "sameAs": [
      "https://www.instagram.com/_rafhin/"
    ],
    "serviceType": [
      "Video Production",
      "Photography",
      "Creative Direction",
      "Automotive Filmmaking",
      "Music Video Production",
      "Commercial Production"
    ]
  }
  </script>

  {# ── favicon ── #}
  <link rel="icon" href="{{ site.favicon }}" type="image/jpeg">

  {# ── fonts ── #}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Archivo:ital,wdth,wght@0,75..125,100..900;1,75..125,100..900&family=Azeret+Mono:wght@400;500&family=IvyPresto+Display:ital,wght@0,400;1,400&display=swap" rel="stylesheet">

  {# ── base styles ── #}
  <link rel="stylesheet" href="/styles/base/tokens.css">
  <link rel="stylesheet" href="/styles/base/reset.css">
  <link rel="stylesheet" href="/styles/base/typography.css">

  {# ── component styles ── #}
  <link rel="stylesheet" href="/styles/components/loader.css">
  <link rel="stylesheet" href="/styles/components/nav.css">
  <link rel="stylesheet" href="/styles/components/footer.css">
  <link rel="stylesheet" href="/styles/components/buttons.css">
  <link rel="stylesheet" href="/styles/components/layout.css">

  {# ── page styles ── #}
  {% if pageCSS %}
  <link rel="stylesheet" href="/styles/pages/{{ pageCSS }}">
  {% endif %}
</head>
<body>

  {% include "components/loader.njk" %}

  <div id="pageContent" style="opacity:1">

    {% include "components/nav.njk" %}
    {% include "components/nav-overlay.njk" %}

    {{ content | safe }}

    {% include "components/footer.njk" %}

  </div>

  {# ── animation library ── #}
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

  {# ── core scripts (every page) ── #}
  <script src="/scripts/core/nav.js"></script>
  <script src="/scripts/core/loader.js"></script>

  {# ── page scripts (opt-in via frontmatter) ── #}
  {% if pageScripts %}
  {% for script in pageScripts %}
  <script src="/scripts/pages/{{ script }}"></script>
  {% endfor %}
  {% endif %}

</body>
</html>
