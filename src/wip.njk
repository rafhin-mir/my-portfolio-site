  <div class="wip-overlay"></div>

  <div class="wip-content">
    <div class="wip-stripe"></div>
    <p class="wip-italic">work in progress</p>
    <p class="wip-title">RAFHIN VISUALS</p>
    <p class="wip-desc">Something great is taking shape.</p>
    <form class="wip-form" id="wipForm" novalidate>
      <div class="wip-input-row">
        <input
          type="password"
          id="wipPassword"
          class="wip-input"
          placeholder="Preview password"
          autocomplete="current-password"
          spellcheck="false"
        >
        <button type="submit" class="wip-submit">Enter &nbsp;→</button>
      </div>
      <p class="wip-error" id="wipError" aria-live="polite">Incorrect password. Try again.</p>
    </form>
  </div>

