---
layout: layouts/base.njk
title: "Contact — Rafhin Visuals"
pageKey: contact
pageCSS: contact.css
permalink: /contact.html
---

<main class="contact-main">
  <h1 class="contact-heading">Contact</h1>

  <div class="contact-cards">
    <a href="mailto:{{ contact.email }}" class="contact-card">
      <p class="contact-card-label">Email</p>
      <p class="contact-card-value">{{ contact.email }}</p>
    </a>
    <a href="{{ contact.instagramUrl }}" class="contact-card" target="_blank" rel="noopener">
      <p class="contact-card-label">Instagram</p>
      <p class="contact-card-value">{{ contact.instagram }}</p>
    </a>
    <a href="tel:{{ contact.phoneHref }}" class="contact-card">
      <p class="contact-card-label">Phone</p>
      <p class="contact-card-value">{{ contact.phone }}</p>
    </a>
  </div>
</main>
